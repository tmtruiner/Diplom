#PostgreSQL
POSTGRES_DB=churn_db
POSTGRES_USER=admin
POSTGRES_PASSWORD=1111
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg2://admin:1111@localhost:5432/churn_db

#MLflow
MLFLOW_PORT=5000
MLFLOW_BACKEND_STORE_URI=postgresql+psycopg2://admin:1111@db:5432/mlflow_db
MLFLOW_ARTIFACT_ROOT=s3://mlflow-artifacts/

#MinIO
MINIO_ROOT_USER=minio_user
MINIO_ROOT_PASSWORD=minio_user_pwd
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MLFLOW_BUCKET_NAME=mlflow-artifacts
MLFLOW_S3_ENDPOINT_URL=http://localhost:9000

MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=churn_prediction
MLFLOW_MODEL_URI=models:/churn_classifier/latest

MINIO_ROOT_USER=minio_user
MINIO_ROOT_PASSWORD=minio_user_pwd

AWS_ACCESS_KEY_ID=minio_user
AWS_SECRET_ACCESS_KEY=minio_user_pwd

HIGH_RISK_THRESHOLD=0.70
MEDIUM_RISK_THRESHOLD=0.35